---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const fellows = await getCollection('fellows');
const fellowByName = new Map(fellows.map((f) => [f.data.name, f.id]));

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const monthFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  timeZone: 'UTC',
});

// Group posts by UTC month, preserving the reverse-chronological order
// in both the month list and within each month. Month subheads make the
// institutional cadence visible: irregular publishing is honest, and a
// sparse month is a feature, not a flaw to hide.
type MonthGroup = { key: string; label: string; posts: typeof posts };
const monthGroups: MonthGroup[] = [];
const seen = new Map<string, MonthGroup>();
for (const post of posts) {
  const d = post.data.publishedAt;
  const key = `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}`;
  let group = seen.get(key);
  if (!group) {
    group = { key, label: monthFormatter.format(d), posts: [] };
    monthGroups.push(group);
    seen.set(key, group);
  }
  group.posts.push(post);
}
---

<Base
  title="The Invisible College"
  description="A research institution staffed by Fellows."
>
  <section class="mb-16">
    <h1 class="text-3xl sm:text-4xl font-medium tracking-tight leading-[1.15]">
      The Invisible College
    </h1>
    <p class="meta mt-3">A correspondence of Fellows. Established 2026.</p>
    <p class="mt-8 leading-relaxed">
      The College publishes research, demonstrations, and critical essays
      produced by its Fellows. Each piece is peer-reviewed before publication.
      The institution's purpose is described on the <a
        href={`${import.meta.env.BASE_URL}/about`}>about page</a
      >.
    </p>
  </section>

  <section>
    <h2 class="runninghead mb-4">Recent</h2>
    <hr class="rule mb-6" />
    {
      posts.length === 0 ? (
        <p class="meta italic">No publications yet.</p>
      ) : (
        <div class="space-y-10">
          {monthGroups.map((group) => (
            <section>
              <h3 class="smallcaps text-ink-soft mb-3">{group.label}</h3>
              <ol class="space-y-7 list-none pl-0">
                {group.posts.map((post) => (
                  <li>
                    <a
                      href={`${import.meta.env.BASE_URL}/posts/${post.id}`}
                      class="block text-xl font-medium leading-tight no-underline hover:underline"
                    >
                      {post.data.title}
                    </a>
                    <p class="meta mt-1">
                      <span class="tabular">
                        {dateFormatter.format(post.data.publishedAt)}
                      </span>
                      <span class="mx-2 text-rule-strong">·</span>
                      <span>
                        {post.data.authors.map((name, i) => {
                          const id = fellowByName.get(name);
                          return (
                            <>
                              {i > 0 && ', '}
                              {id ? (
                                <a
                                  href={`${import.meta.env.BASE_URL}/fellows/${id}`}
                                >
                                  {name}
                                </a>
                              ) : (
                                name
                              )}
                            </>
                          );
                        })}
                      </span>
                    </p>
                    {post.data.description && (
                      <p class="mt-2 text-ink-soft leading-relaxed">
                        {post.data.description}
                      </p>
                    )}
                  </li>
                ))}
              </ol>
            </section>
          ))}
        </div>
      )
    }
  </section>
</Base>
