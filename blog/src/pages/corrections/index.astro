---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';
import ArticleHeader from '../../components/ArticleHeader.astro';
import { longDateFormatter } from '../../lib/date-formatters';
import { correctionSeverityLabel, labelFor } from '../../lib/labels';

const corrections = await getCollection('corrections');
corrections.sort((a, b) => b.data.issuedAt.getTime() - a.data.issuedAt.getTime());

// Resolve each post slug to its title.
const postTitleBySlug: Record<string, string> = {};
for (const c of corrections) {
  const post = await getEntry('posts', c.data.postSlug);
  postTitleBySlug[c.data.postSlug] = post?.data.title ?? c.data.postSlug;
}
---

<Base
  title="Corrections"
  description="Corrections, clarifications, and retractions issued by the Invisible College after publication."
>
  <article>
    <ArticleHeader eyebrow="Corrections" title="Corrections">
      <p class="meta mt-6 max-w-prose">
        When a published piece needs amendment, the correction is recorded here with its
        reason. Trivial typos and broken links are corrected in place. Factual issues
        and retractions are kept visible: the original error is part of the record, and
        the correction notes what changed and why.
      </p>
    </ArticleHeader>

    {
      corrections.length === 0 && (
        <p class="meta mt-6">No corrections have been issued yet.</p>
      )
    }

    {
      corrections.length > 0 && (
        <ol class="space-y-6 list-none pl-0">
          {corrections.map((c) => (
            <li>
              <p class="meta tabular">
                {longDateFormatter.format(c.data.issuedAt)}
                <span class="mx-2 text-rule-strong">·</span>
                <span class="smallcaps">
                  {labelFor(correctionSeverityLabel, c.data.severity)}
                </span>
              </p>
              <p class="mt-1">
                <a
                  href={`${import.meta.env.BASE_URL}/posts/${c.data.postSlug}`}
                  class="font-medium no-underline hover:underline"
                >
                  {postTitleBySlug[c.data.postSlug]}
                </a>
              </p>
              <p class="meta mt-2 max-w-prose">{c.data.summary}</p>
            </li>
          ))}
        </ol>
      )
    }
  </article>
</Base>
