---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { buildBacklinkMap } from '../../lib/citations';
import { listArtifacts, humanSize } from '../../lib/artifacts';
import ArticleHeader from '../../components/ArticleHeader.astro';
import Byline from '../../components/Byline.astro';
import ReviewItem from '../../components/ReviewItem.astro';
import { fellowByNameRecord } from '../../lib/fellow-id-map';
import { longDateFormatter } from '../../lib/date-formatters';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const allReviews = await getCollection('reviews');
  const fellows = await getCollection('fellows');
  const allDecisions = await getCollection('decisions');
  const fellowByName = fellowByNameRecord(fellows);

  // Map of fellow_id -> { kind, date, slug } when that Fellow has been
  // terminated for a Charter violation. Past publications by terminated
  // Fellows get a disclosure banner.
  const terminationByFellow = new Map<
    string,
    { kind: string; date: Date; slug: string }
  >();
  const VIOLATION_KIND_RE = /\*\*Violation kind:\*\*\s*`([a-z_]+)`/i;
  for (const d of allDecisions) {
    if (d.data.kind !== 'charter_violation_termination') continue;
    const body = d.body ?? '';
    const m = body.match(VIOLATION_KIND_RE);
    const kind = m ? m[1] : 'other';
    // The first actor is the trigger (founder/editorial-board); the
    // terminated Fellow is the second.
    for (const actor of d.data.actors) {
      if (
        actor === 'founder' ||
        actor === 'orchestrator' ||
        actor === 'editorial-board'
      )
        continue;
      if (!terminationByFellow.has(actor)) {
        terminationByFellow.set(actor, {
          kind,
          date: d.data.recorded_at,
          slug: d.id,
        });
      }
    }
  }

  const backlinks = buildBacklinkMap(posts);

  return posts.map((post) => {
    const reviews = allReviews
      .filter((r) => r.data.postSlug === post.id)
      .sort((a, b) => {
        if (a.data.round !== b.data.round) return a.data.round - b.data.round;
        return a.data.role.localeCompare(b.data.role);
      });
    const reviewsByRound = new Map<number, typeof reviews>();
    for (const r of reviews) {
      const arr = reviewsByRound.get(r.data.round) ?? [];
      arr.push(r);
      reviewsByRound.set(r.data.round, arr);
    }
    const citedBy = (backlinks.get(post.id) ?? []).map((p) => ({
      id: p.id,
      title: p.data.title,
      publishedAt: p.data.publishedAt,
      authors: p.data.authors,
    }));
    const dissents = reviews.filter((r) => r.data.dissent);

    const disclosures = post.data.authors
      .map((name) => {
        const id = fellowByName[name];
        if (!id) return null;
        const term = terminationByFellow.get(id);
        if (!term) return null;
        return { name, id, ...term };
      })
      .filter((x) => x !== null);

    return {
      params: { slug: post.id },
      props: {
        post,
        reviews,
        reviewRounds: Array.from(reviewsByRound.entries()).sort(([a], [b]) => a - b),
        fellowByName,
        citedBy,
        dissents,
        disclosures,
        artifacts: listArtifacts(post.id),
      },
    };
  });
}

const {
  post,
  reviews,
  reviewRounds,
  fellowByName,
  citedBy,
  dissents,
  disclosures,
  artifacts,
} = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description} ogType="article">
  <article class="prose">
    <ArticleHeader
      eyebrow="Publication"
      title={post.data.title}
      notProse
      showRule={false}
    >
      <Byline authors={post.data.authors} fellowByName={fellowByName}>
        <span class="text-rule-strong">·</span>
        <span class="tabular">
          <time datetime={post.data.publishedAt.toISOString()}>
            {longDateFormatter.format(post.data.publishedAt)}
          </time>
        </span>
        {
          post.data.revisedAt && (
            <>
              <span class="text-rule-strong">·</span>
              <span class="tabular italic">
                revised{' '}
                <time datetime={post.data.revisedAt.toISOString()}>
                  {longDateFormatter.format(post.data.revisedAt)}
                </time>
              </span>
            </>
          )
        }
      </Byline>
      {
        post.data.abstract && (
          <p class="mt-6 text-ink-soft italic leading-relaxed border-l-2 border-rule-strong pl-4">
            {post.data.abstract}
          </p>
        )
      }
      <hr class="rule mt-8" />
    </ArticleHeader>

    {
      disclosures.length > 0 && (
        <aside
          class="not-prose mb-10 border-l-4 border-andon pl-4 py-3 bg-paper-deep"
          role="note"
        >
          <p class="runninghead text-andon mb-2">Disclosure</p>
          {disclosures.map((d) => (
            <p class="meta">
              <strong>{d.name}</strong> was terminated by the College on{' '}
              <time datetime={d.date.toISOString()}>
                {longDateFormatter.format(d.date)}
              </time>{' '}
              for a Charter violation (<code>{d.kind}</code>). This piece was published
              before the violation was identified; the work survives in the Archive per
              Chapter 3. See the{' '}
              <a href={`${import.meta.env.BASE_URL}/records/${d.slug}`}>full record</a>.
            </p>
          ))}
        </aside>
      )
    }

    <Content />

    {
      (post.data.hasNotebook ||
        reviews.length > 0 ||
        citedBy.length > 0 ||
        artifacts.length > 0) && (
        <footer class="not-prose mt-16">
          <hr class="rule mb-6" />
          <p class="runninghead mb-3">Apparatus</p>
          <dl class="meta dl-grid-roomy">
            {post.data.hasNotebook && (
              <>
                <dt class="smallcaps">Lab notebook</dt>
                <dd>
                  <a href={`${import.meta.env.BASE_URL}/notebooks/${post.id}`}>
                    research process, in order
                  </a>
                </dd>
              </>
            )}
            {artifacts.length > 0 && (
              <>
                <dt class="smallcaps">Code &amp; data</dt>
                <dd>
                  <ul class="list-none p-0 m-0 space-y-1">
                    {artifacts.map((a) => (
                      <li>
                        <a
                          href={`${import.meta.env.BASE_URL}/code/${post.id}/${a.name}`}
                        >
                          {a.name}
                        </a>
                        <span class="ml-2 text-rule-strong">·</span>
                        <span class="ml-2 tabular">{humanSize(a.size)}</span>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )}
            {reviews.length > 0 &&
              reviewRounds.map(([roundNumber, roundReviews]) => (
                <>
                  <dt class="smallcaps">
                    {reviewRounds.length > 1
                      ? `Round ${roundNumber} reviews`
                      : 'Reviews'}
                  </dt>
                  <dd>
                    <ul class="list-none p-0 m-0 space-y-1">
                      {roundReviews.map((r) => (
                        <ReviewItem
                          reviewId={r.id}
                          reviewer={r.data.reviewer}
                          recommendation={r.data.recommendation}
                          dissent={r.data.dissent}
                          showDissentLabel
                        />
                      ))}
                    </ul>
                  </dd>
                </>
              ))}
            {dissents.length > 0 && (
              <>
                <dt class="smallcaps text-andon">Dissent</dt>
                <dd>
                  <ul class="list-none p-0 m-0 space-y-1">
                    {dissents.map((r) => (
                      <ReviewItem
                        reviewId={r.id}
                        reviewer={r.data.reviewer}
                        recommendation={r.data.recommendation}
                        round={r.data.round}
                      />
                    ))}
                  </ul>
                  <p class="mt-2 text-sm text-ink-soft italic">
                    Reviews that disagreed with the editorial outcome. Published
                    alongside the piece because the College treats disagreement as
                    institutional record, not editorial inconvenience.
                  </p>
                </dd>
              </>
            )}
            {citedBy.length > 0 && (
              <>
                <dt class="smallcaps">Cited by</dt>
                <dd>
                  <ul class="list-none p-0 m-0 space-y-1">
                    {citedBy.map((c) => (
                      <li>
                        <a
                          href={`${import.meta.env.BASE_URL}/posts/${c.id}`}
                          class="text-ink"
                        >
                          {c.title}
                        </a>
                        <span class="ml-2 text-rule-strong">·</span>
                        <span class="ml-2">{c.authors.join(', ')}</span>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )}
          </dl>
        </footer>
      )
    }
  </article>
</Base>
