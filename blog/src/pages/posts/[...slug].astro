---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { buildBacklinkMap } from '../../lib/citations';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const allReviews = await getCollection('reviews');
  const fellows = await getCollection('fellows');
  // name -> fellow id, used to turn bylines into profile links.
  const fellowByName = new Map(fellows.map((f) => [f.data.name, f.id]));

  const backlinks = buildBacklinkMap(posts);

  return posts.map((post) => {
    const reviews = allReviews
      .filter((r) => r.data.postSlug === post.id)
      .sort((a, b) => {
        if (a.data.round !== b.data.round) return a.data.round - b.data.round;
        return a.data.role.localeCompare(b.data.role);
      });
    const reviewsByRound = new Map<number, typeof reviews>();
    for (const r of reviews) {
      const arr = reviewsByRound.get(r.data.round) ?? [];
      arr.push(r);
      reviewsByRound.set(r.data.round, arr);
    }
    const citedBy = (backlinks.get(post.id) ?? []).map((p) => ({
      id: p.id,
      title: p.data.title,
      publishedAt: p.data.publishedAt,
      authors: p.data.authors,
    }));
    const dissents = reviews.filter((r) => r.data.dissent);
    return {
      params: { slug: post.id },
      props: {
        post,
        reviews,
        reviewRounds: Array.from(reviewsByRound.entries()).sort(
          ([a], [b]) => a - b,
        ),
        fellowByName: Object.fromEntries(fellowByName),
        citedBy,
        dissents,
      },
    };
  });
}

const { post, reviews, reviewRounds, fellowByName, citedBy, dissents } =
  Astro.props;
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogType="article"
>
  <article class="prose">
    <header class="mb-12 not-prose">
      <p class="runninghead">Publication</p>
      <h1
        class="mt-3 text-3xl sm:text-[2.4rem] font-medium tracking-tight leading-[1.1]"
      >
        {post.data.title}
      </h1>
      <div class="meta mt-5 flex flex-wrap gap-x-4 gap-y-1 items-baseline">
        <span>
          {
            post.data.authors.map((name, i) => {
              const id = fellowByName[name];
              return (
                <>
                  {i > 0 && ', '}
                  {id ? (
                    <a href={`${import.meta.env.BASE_URL}/fellows/${id}`}>
                      {name}
                    </a>
                  ) : (
                    name
                  )}
                </>
              );
            })
          }
        </span>
        <span class="text-rule-strong">·</span>
        <span class="tabular">
          <time datetime={post.data.publishedAt.toISOString()}>
            {dateFormatter.format(post.data.publishedAt)}
          </time>
        </span>
        {
          post.data.revisedAt && (
            <>
              <span class="text-rule-strong">·</span>
              <span class="tabular italic">
                revised{' '}
                <time datetime={post.data.revisedAt.toISOString()}>
                  {dateFormatter.format(post.data.revisedAt)}
                </time>
              </span>
            </>
          )
        }
      </div>
      {
        post.data.abstract && (
          <p class="mt-6 text-ink-soft italic leading-relaxed border-l-2 border-rule-strong pl-4">
            {post.data.abstract}
          </p>
        )
      }
      <hr class="rule mt-8" />
    </header>

    <Content />

    {
      (post.data.hasNotebook || reviews.length > 0 || citedBy.length > 0) && (
        <footer class="not-prose mt-16">
          <hr class="rule mb-6" />
          <p class="runninghead mb-3">Apparatus</p>
          <dl class="meta grid grid-cols-[max-content_1fr] gap-x-6 gap-y-2">
            {post.data.hasNotebook && (
              <>
                <dt class="smallcaps">Lab notebook</dt>
                <dd>
                  <a href={`${import.meta.env.BASE_URL}/notebooks/${post.id}`}>
                    research process, in order
                  </a>
                </dd>
              </>
            )}
            {reviews.length > 0 &&
              reviewRounds.map(([roundNumber, roundReviews]) => (
                <>
                  <dt class="smallcaps">
                    {reviewRounds.length > 1
                      ? `Round ${roundNumber} reviews`
                      : 'Reviews'}
                  </dt>
                  <dd>
                    <ul class="list-none p-0 m-0 space-y-1">
                      {roundReviews.map((r) => (
                        <li>
                          <a
                            href={`${import.meta.env.BASE_URL}/reviews/${r.id}`}
                          >
                            {r.data.reviewer}
                          </a>
                          <span class="ml-2 text-rule-strong">·</span>
                          <span class="ml-2">{r.data.recommendation}</span>
                          {r.data.dissent && (
                            <span class="ml-2 font-medium text-andon">
                              dissent
                            </span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </dd>
                </>
              ))}
            {dissents.length > 0 && (
              <>
                <dt class="smallcaps text-andon">Dissent</dt>
                <dd>
                  <ul class="list-none p-0 m-0 space-y-1">
                    {dissents.map((r) => (
                      <li>
                        <a href={`${import.meta.env.BASE_URL}/reviews/${r.id}`}>
                          {r.data.reviewer}
                        </a>
                        <span class="ml-2 text-rule-strong">·</span>
                        <span class="ml-2">round {r.data.round}</span>
                        <span class="ml-2 text-rule-strong">·</span>
                        <span class="ml-2">{r.data.recommendation}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="mt-2 text-sm text-ink-soft italic">
                    Reviews that disagreed with the editorial outcome. Published
                    alongside the piece because the College treats disagreement
                    as institutional record, not editorial inconvenience.
                  </p>
                </dd>
              </>
            )}
            {citedBy.length > 0 && (
              <>
                <dt class="smallcaps">Cited by</dt>
                <dd>
                  <ul class="list-none p-0 m-0 space-y-1">
                    {citedBy.map((c) => (
                      <li>
                        <a
                          href={`${import.meta.env.BASE_URL}/posts/${c.id}`}
                          class="text-ink"
                        >
                          {c.title}
                        </a>
                        <span class="ml-2 text-rule-strong">·</span>
                        <span class="ml-2">{c.authors.join(', ')}</span>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )}
          </dl>
        </footer>
      )
    }
  </article>
</Base>
