---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { longDateFormatter } from '../../lib/date-formatters';
import { decisionKindLabel, labelFor } from '../../lib/labels';

export async function getStaticPaths() {
  const decisions = await getCollection('decisions');
  return decisions.map((d) => ({
    params: { slug: d.id },
    props: { decision: d },
  }));
}

const { decision } = Astro.props;
const { Content } = await render(decision);
---

<Base title="Record" description="An institutional decision of the Invisible College.">
  <article class="prose">
    <header class="mb-10 not-prose">
      <p class="runninghead">
        Record · {labelFor(decisionKindLabel, decision.data.kind)}
      </p>
      <p class="meta mt-3 tabular">
        <time datetime={decision.data.recorded_at.toISOString()}>
          {longDateFormatter.format(decision.data.recorded_at)}
        </time>
        {
          decision.data.actors.length > 0 && (
            <>
              <span class="mx-2 text-rule-strong">·</span>
              <span>{decision.data.actors.join(', ')}</span>
            </>
          )
        }
      </p>
      <hr class="rule mt-6" />
    </header>
    <Content />
    <p class="meta mt-12 not-prose">
      <a href={`${import.meta.env.BASE_URL}/records`}>← All records</a>
    </p>
  </article>
</Base>
