---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const decisions = await getCollection('decisions');
  return decisions.map((d) => ({
    params: { slug: d.id },
    props: { decision: d },
  }));
}

const { decision } = Astro.props;
const { Content } = await render(decision);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const kindLabel: Record<string, string> = {
  bootstrap: 'Founding',
  admission: 'Admission',
  promotion: 'Promotion',
  promotion_review: 'Promotion review',
  release: 'Release',
  andon_cord_pulled: 'Andon cord pulled',
  andon_cord_outcome: 'Andon ruling',
  editorial_ruling: 'Editorial ruling',
  charter_violation_termination: 'Termination (Charter)',
};
---

<Base
  title="Record"
  description="An institutional decision of the Invisible College."
>
  <article class="prose">
    <header class="mb-10 not-prose">
      <p class="runninghead">
        Record · {kindLabel[decision.data.kind] ?? decision.data.kind}
      </p>
      <p class="meta mt-3 tabular">
        <time datetime={decision.data.recorded_at.toISOString()}>
          {dateFormatter.format(decision.data.recorded_at)}
        </time>
        {
          decision.data.actors.length > 0 && (
            <>
              <span class="mx-2 text-rule-strong">·</span>
              <span>{decision.data.actors.join(', ')}</span>
            </>
          )
        }
      </p>
      <hr class="rule mt-6" />
    </header>
    <Content />
    <p class="meta mt-12 not-prose">
      <a href={`${import.meta.env.BASE_URL}/records`}>← All records</a>
    </p>
  </article>
</Base>
