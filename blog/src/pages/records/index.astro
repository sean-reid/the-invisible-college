---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ArticleHeader from '../../components/ArticleHeader.astro';
import ListItem from '../../components/ListItem.astro';
import { shortDateFormatter } from '../../lib/date-formatters';
import { decisionKindLabel, labelFor } from '../../lib/labels';

const decisions = (await getCollection('decisions')).sort(
  (a, b) => b.data.recorded_at.getTime() - a.data.recorded_at.getTime(),
);

// Each decision's first H1 heading in the body is the real title.
// Falls back to a dehyphenated slug if the body has no H1.
function displayTitle(body: string, slug: string): string {
  const m = body.match(/^#\s+(.+?)\s*$/m);
  if (m) return m[1].trim();
  return slug
    .replace(/^\d{4}-\d{2}-\d{2}-/, '')
    .replace(/-/g, ' ')
    .replace(/^./, (c) => c.toUpperCase());
}
---

<Base
  title="Records"
  description="Institutional decisions of the Invisible College: admissions, promotions, releases, editorial rulings, andon-cord pulls."
>
  <article class="prose">
    <ArticleHeader
      eyebrow="Records"
      title="Records"
      size="section"
      spacing="tight"
      notProse
      ruleMargin="mt-6"
    >
      <p class="meta mt-4 max-w-prose">
        The institutional decisions of the College, newest first. Admissions,
        promotions, releases, editorial rulings on disputed pieces, and andon-cord
        pulls. Research-flow events (peer reviews, lab notebooks) live with their
        publications.
      </p>
    </ArticleHeader>

    {
      decisions.length === 0 ? (
        <p class="meta">No records yet.</p>
      ) : (
        <section aria-labelledby="records-list">
          <h2 id="records-list" class="runninghead mb-4">
            Recorded decisions
          </h2>
          <hr class="rule mb-6" />
          <ol class="not-prose space-y-5 list-none pl-0">
            {decisions.map((d) => (
              <ListItem
                href={`${import.meta.env.BASE_URL}/records/${d.id}`}
                title={displayTitle(d.body ?? '', d.id)}
                size="md"
              >
                <Fragment slot="meta-above">
                  <time class="tabular" datetime={d.data.recorded_at.toISOString()}>
                    {shortDateFormatter.format(d.data.recorded_at)}
                  </time>
                  <span class="text-rule-strong">·</span>
                  <span class="runninghead">
                    {labelFor(decisionKindLabel, d.data.kind)}
                  </span>
                </Fragment>
              </ListItem>
            ))}
          </ol>
        </section>
      )
    }
  </article>
</Base>
