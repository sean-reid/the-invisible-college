---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  const fellows = await getCollection('fellows');
  const fellowByName = Object.fromEntries(
    fellows.map((f) => [f.data.name, f.id]),
  );
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review, reviewerId: fellowByName[review.data.reviewer] ?? null },
  }));
}

const { review, reviewerId } = Astro.props;
const { Content } = await render(review);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const recommendationLabel: Record<string, string> = {
  accept: 'Accept',
  minor: 'Accept with minor revisions',
  major: 'Major revisions required',
  reject: 'Reject',
};

const roleLabel: Record<string, string> = {
  primary: 'Primary reviewer',
  secondary: 'Secondary reviewer',
  outside: 'Outside reviewer',
};
---

<Base title={`Review by ${review.data.reviewer}`}>
  <article class="prose">
    <header class="mb-10 not-prose">
      <p class="runninghead">Peer review</p>
      <h1
        class="mt-3 text-2xl sm:text-3xl font-medium tracking-tight leading-[1.15]"
      >
        {review.data.title}
      </h1>
      <dl class="meta mt-5 grid grid-cols-[max-content_1fr] gap-x-6 gap-y-2">
        <dt class="smallcaps">Reviewer</dt>
        <dd>
          {
            reviewerId ? (
              <a href={`${import.meta.env.BASE_URL}/fellows/${reviewerId}`}>
                {review.data.reviewer}
              </a>
            ) : (
              review.data.reviewer
            )
          } ({roleLabel[review.data.role]})
        </dd>

        <dt class="smallcaps">Submitted</dt>
        <dd class="tabular">
          <time datetime={review.data.submittedAt.toISOString()}>
            {dateFormatter.format(review.data.submittedAt)}
          </time>
        </dd>

        <dt class="smallcaps">Recommendation</dt>
        <dd>{recommendationLabel[review.data.recommendation]}</dd>

        <dt class="smallcaps">Confidence</dt>
        <dd>{review.data.confidence}</dd>

        {
          review.data.dissent && (
            <>
              <dt class="smallcaps">Note</dt>
              <dd class="italic">
                This review dissents from the editorial decision and is
                preserved alongside the published piece.
              </dd>
            </>
          )
        }
      </dl>
      <p class="meta mt-4">
        Review of{' '}
        <a href={`${import.meta.env.BASE_URL}/posts/${review.data.postSlug}`}
          >the publication</a
        >.
      </p>
      <hr class="rule mt-6" />
    </header>

    <Content />
  </article>
</Base>
