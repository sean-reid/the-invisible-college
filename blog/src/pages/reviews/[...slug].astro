---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import ArticleHeader from '../../components/ArticleHeader.astro';
import { fellowByNameRecord } from '../../lib/fellow-id-map';
import { longDateFormatter } from '../../lib/date-formatters';
import { recommendationLabel, roleLabel, labelFor } from '../../lib/labels';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  const fellows = await getCollection('fellows');
  const byName = fellowByNameRecord(fellows);
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review, reviewerId: byName[review.data.reviewer] ?? null },
  }));
}

const { review, reviewerId } = Astro.props;
const { Content } = await render(review);
---

<Base title={`Review by ${review.data.reviewer}`}>
  <article class="prose">
    <ArticleHeader
      eyebrow="Peer review"
      title={review.data.title}
      size="sub"
      spacing="tight"
      notProse
      ruleMargin="mt-6"
      showRule={false}
    >
      <dl class="meta mt-5 grid grid-cols-[max-content_1fr] gap-x-6 gap-y-2">
        <dt class="smallcaps">Reviewer</dt>
        <dd>
          {
            reviewerId ? (
              <a href={`${import.meta.env.BASE_URL}/fellows/${reviewerId}`}>
                {review.data.reviewer}
              </a>
            ) : (
              review.data.reviewer
            )
          } ({labelFor(roleLabel, review.data.role)})
        </dd>

        <dt class="smallcaps">Submitted</dt>
        <dd class="tabular">
          <time datetime={review.data.submittedAt.toISOString()}>
            {longDateFormatter.format(review.data.submittedAt)}
          </time>
        </dd>

        <dt class="smallcaps">Recommendation</dt>
        <dd>{labelFor(recommendationLabel, review.data.recommendation)}</dd>

        <dt class="smallcaps">Confidence</dt>
        <dd>{review.data.confidence}</dd>

        {
          review.data.dissent && (
            <>
              <dt class="smallcaps">Note</dt>
              <dd class="italic">
                This review dissents from the editorial decision and is
                preserved alongside the published piece.
              </dd>
            </>
          )
        }
      </dl>
      <p class="meta mt-4">
        Review of{' '}
        <a href={`${import.meta.env.BASE_URL}/posts/${review.data.postSlug}`}
          >the publication</a
        >.
      </p>
      <hr class="rule mt-6" />
    </ArticleHeader>

    <Content />
  </article>
</Base>
