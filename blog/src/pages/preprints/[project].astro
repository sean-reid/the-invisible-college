---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { longDateFormatter } from '../../lib/date-formatters';

type PreprintEntry = Awaited<
  ReturnType<typeof getCollection<'preprints'>>
>[number];

export async function getStaticPaths() {
  const all = await getCollection('preprints');
  const byProject = new Map<string, PreprintEntry[]>();
  for (const entry of all) {
    const list = byProject.get(entry.data.projectId);
    if (list) list.push(entry);
    else byProject.set(entry.data.projectId, [entry]);
  }
  const paths = [];
  for (const [projectId, versions] of byProject) {
    versions.sort((a, b) => b.data.version - a.data.version);
    paths.push({
      params: { project: projectId },
      props: { latestEntry: versions[0], olderEntries: versions.slice(1) },
    });
  }
  return paths;
}

interface Props {
  latestEntry: PreprintEntry;
  olderEntries: PreprintEntry[];
}

const { latestEntry, olderEntries } = Astro.props as Props;
const latest = latestEntry.data;
const { Content } = await render(latestEntry);
---

<Base
  title={`Preprint: ${latest.title}`}
  description={latest.abstract || `Working preprint by ${latest.lead}.`}
  ogType="article"
>
  <article class="prose">
    <header class="mb-10 not-prose">
      <p class="runninghead">Working preprint · v{latest.version}</p>
      <h1
        class="mt-3 text-3xl sm:text-[2.4rem] font-medium tracking-tight leading-[1.1]"
      >
        {latest.title}
      </h1>
      <div class="meta mt-5 flex flex-wrap gap-x-4 gap-y-1 items-baseline">
        <span>
          {
            latest.leadId ? (
              <a href={`${import.meta.env.BASE_URL}/fellows/${latest.leadId}`}>
                {latest.lead}
              </a>
            ) : (
              latest.lead
            )
          }
        </span>
        <span class="text-rule-strong">·</span>
        <span class="tabular">
          <time datetime={latest.postedAt.toISOString()}>
            {longDateFormatter.format(latest.postedAt)}
          </time>
        </span>
        <span class="text-rule-strong">·</span>
        <span class="tabular">version {latest.version}</span>
      </div>
      {
        latest.abstract && (
          <p class="mt-6 text-ink-soft italic leading-relaxed border-l-2 border-rule-strong pl-4">
            {latest.abstract}
          </p>
        )
      }
      <aside
        class="mt-6 border-l-4 border-andon pl-4 py-3 bg-paper-deep"
        role="note"
      >
        <p class="runninghead text-andon mb-1">Provisional</p>
        <p class="meta">
          This is a working preprint, not a publication. It has not been peer
          reviewed. The lead Fellow may revise it, post a follow-up version, or
          eventually route the work through the College's normal publish
          pipeline. The College's peer-reviewed record lives at <a
            href={`${import.meta.env.BASE_URL}/archive`}>the archive</a
          >.
        </p>
      </aside>
      <hr class="rule mt-8" />
    </header>

    <Content />

    {
      olderEntries.length > 0 && (
        <footer class="not-prose mt-16">
          <hr class="rule mb-6" />
          <p class="runninghead mb-3">Earlier versions</p>
          <ul class="meta list-none p-0 m-0 space-y-2">
            {olderEntries.map((v) => (
              <li class="flex items-baseline gap-x-3">
                <span class="tabular">v{v.data.version}</span>
                <span class="text-rule-strong">·</span>
                <span class="tabular">
                  {longDateFormatter.format(v.data.postedAt)}
                </span>
                {v.data.abstract && (
                  <>
                    <span class="text-rule-strong">·</span>
                    <span class="text-ink-soft italic">{v.data.abstract}</span>
                  </>
                )}
              </li>
            ))}
          </ul>
          <p class="meta mt-3 text-ink-soft">
            Older versions are preserved as institutional record. They are not
            rendered as separate pages; the body above is the latest.
          </p>
        </footer>
      )
    }
  </article>
</Base>
