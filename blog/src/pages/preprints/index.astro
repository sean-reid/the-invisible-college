---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ArticleHeader from '../../components/ArticleHeader.astro';
import { longDateFormatter } from '../../lib/date-formatters';

// Group preprint version entries by project, newest version first.
type PreprintEntry = Awaited<ReturnType<typeof getCollection<'preprints'>>>[number];
type ProjectGroup = {
  projectId: string;
  latest: PreprintEntry;
  versions: PreprintEntry[]; // newest first
};

const entries = await getCollection('preprints');
const byProject = new Map<string, PreprintEntry[]>();
for (const entry of entries) {
  const list = byProject.get(entry.data.projectId);
  if (list) list.push(entry);
  else byProject.set(entry.data.projectId, [entry]);
}

const projects: ProjectGroup[] = [];
for (const [projectId, versions] of byProject) {
  versions.sort((a, b) => b.data.version - a.data.version);
  projects.push({ projectId, latest: versions[0], versions });
}
// Newest-posted project first.
projects.sort(
  (a, b) => b.latest.data.postedAt.getTime() - a.latest.data.postedAt.getTime(),
);
---

<Base
  title="Working preprints"
  description="Public-but-provisional snapshots of in-flight work at the Invisible College. Not peer reviewed; surfaced for low-stakes reaction."
>
  <article>
    <ArticleHeader
      eyebrow="Preprints"
      title="Working preprints"
      size="section"
      spacing="tight"
      ruleMargin="mt-8"
      showRule={false}
    >
      <p class="meta mt-4 max-w-prose">
        Deliberate checkpoints of in-flight research. Posted by a lead Fellow
        mid-project as work-in-progress, not as a publication. None of these have passed
        peer review.
      </p>
      <aside
        class="mt-6 border-l-4 border-andon pl-4 py-3 bg-paper-deep not-prose"
        role="note"
        aria-labelledby="preprints-provisional"
      >
        <p id="preprints-provisional" class="runninghead text-andon mb-1">
          Provisional
        </p>
        <p class="meta">
          A preprint is a public reading of work-in-progress. The College's
          peer-reviewed record lives at <a href={`${import.meta.env.BASE_URL}/`}
            >publications</a
          > and at the <a href={`${import.meta.env.BASE_URL}/archive`}>full archive</a>.
          Preprints do not count as publications and are not subject to the editorial
          gate.
        </p>
      </aside>
      <hr class="rule mt-8" />
    </ArticleHeader>

    {
      projects.length === 0 ? (
        <p class="meta italic">No preprints posted yet.</p>
      ) : (
        <section aria-labelledby="preprints-list">
          <h2 id="preprints-list" class="runninghead mb-4">
            Posted preprints
          </h2>
          <hr class="rule mb-6" />
          <ol class="not-prose space-y-7 list-none pl-0">
            {projects.map((p) => (
              <li>
                <a
                  href={`${import.meta.env.BASE_URL}/preprints/${p.projectId}`}
                  class="block text-xl font-medium leading-tight no-underline hover:underline"
                >
                  {p.latest.data.title}
                </a>
                <p class="meta mt-1 flex flex-wrap items-baseline gap-x-2">
                  <span class="tabular">
                    v{p.latest.data.version}
                    {p.versions.length > 1 && (
                      <span class="ml-1 text-ink-soft">
                        ({p.versions.length} versions)
                      </span>
                    )}
                  </span>
                  <span class="text-rule-strong">·</span>
                  <span class="tabular">
                    {longDateFormatter.format(p.latest.data.postedAt)}
                  </span>
                  <span class="text-rule-strong">·</span>
                  <span>
                    {p.latest.data.leadId ? (
                      <a
                        href={`${import.meta.env.BASE_URL}/fellows/${p.latest.data.leadId}`}
                      >
                        {p.latest.data.lead}
                      </a>
                    ) : (
                      p.latest.data.lead
                    )}
                  </span>
                </p>
                {p.latest.data.abstract && (
                  <p class="mt-2 text-ink-soft leading-relaxed">
                    {p.latest.data.abstract}
                  </p>
                )}
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </article>
</Base>
