---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const fellows = await getCollection('fellows');
const fellowByName = new Map(fellows.map((f) => [f.data.name, f.id]));

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});

// Group by UTC year. Within a year, posts stay reverse-chronological.
type YearGroup = { year: number; posts: typeof posts };
const yearGroups: YearGroup[] = [];
const seenYear = new Map<number, YearGroup>();
for (const post of posts) {
  const y = post.data.publishedAt.getUTCFullYear();
  let group = seenYear.get(y);
  if (!group) {
    group = { year: y, posts: [] };
    yearGroups.push(group);
    seenYear.set(y, group);
  }
  group.posts.push(post);
}
---

<Base
  title="Archive"
  description="The full publication record of the Invisible College, newest first."
>
  <article>
    <header class="mb-10">
      <p class="runninghead">Archive</p>
      <h1
        class="mt-3 text-3xl sm:text-4xl font-medium tracking-tight leading-[1.15]"
      >
        Archive
      </h1>
      <p class="meta mt-4 max-w-prose">
        Every publication the College has produced, newest first. The home page
        shows only recent work; this is the full record.
      </p>
      <hr class="rule mt-6" />
    </header>

    {
      yearGroups.length === 0 ? (
        <p class="meta italic">No publications yet.</p>
      ) : (
        <div class="space-y-10">
          {yearGroups.map((group) => (
            <section>
              <h2 class="smallcaps text-ink-soft mb-3">{group.year}</h2>
              <ul class="not-prose list-none p-0 m-0 space-y-4">
                {group.posts.map((post) => (
                  <li>
                    <a
                      href={`${import.meta.env.BASE_URL}/posts/${post.id}`}
                      class="block font-medium text-base text-ink leading-snug no-underline hover:underline"
                    >
                      {post.data.title}
                    </a>
                    <p class="meta mt-1 flex flex-wrap items-baseline gap-x-2">
                      <span class="tabular">
                        {dateFormatter.format(post.data.publishedAt)}
                      </span>
                      <span class="text-rule-strong">·</span>
                      <span>
                        {post.data.authors.map((name, i) => {
                          const id = fellowByName.get(name);
                          return (
                            <>
                              {i > 0 && ', '}
                              {id ? (
                                <a
                                  href={`${import.meta.env.BASE_URL}/fellows/${id}`}
                                >
                                  {name}
                                </a>
                              ) : (
                                name
                              )}
                            </>
                          );
                        })}
                      </span>
                    </p>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )
    }
  </article>
</Base>
