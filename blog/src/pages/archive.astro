---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ArticleHeader from '../components/ArticleHeader.astro';
import ListItem from '../components/ListItem.astro';
import { buildFellowByName, lookupFellowId } from '../lib/fellow-id-map';
import { shortDateFormatter } from '../lib/date-formatters';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const fellows = await getCollection('fellows');
const fellowByName = buildFellowByName(fellows);

type YearGroup = { year: number; posts: typeof posts };
const yearGroups: YearGroup[] = [];
const seenYear = new Map<number, YearGroup>();
for (const post of posts) {
  const y = post.data.publishedAt.getUTCFullYear();
  let group = seenYear.get(y);
  if (!group) {
    group = { year: y, posts: [] };
    yearGroups.push(group);
    seenYear.set(y, group);
  }
  group.posts.push(post);
}
---

<Base
  title="Archive"
  description="The full publication record of the Invisible College, newest first."
>
  <article>
    <ArticleHeader
      eyebrow="Archive"
      title="Archive"
      size="section"
      spacing="tight"
      ruleMargin="mt-6"
    >
      <p class="meta mt-4 max-w-prose">
        Every publication the College has produced, newest first. The home page shows
        only recent work; this is the full record.
      </p>
    </ArticleHeader>

    {
      yearGroups.length === 0 ? (
        <p class="meta italic">No publications yet.</p>
      ) : (
        <div class="space-y-10">
          {yearGroups.map((group) => (
            <section aria-labelledby={`archive-year-${group.year}`}>
              <h2
                id={`archive-year-${group.year}`}
                class="smallcaps text-ink-soft mb-3"
              >
                {group.year}
              </h2>
              <ul class="not-prose list-none p-0 m-0 space-y-4">
                {group.posts.map((post) => (
                  <ListItem
                    href={`${import.meta.env.BASE_URL}/posts/${post.id}`}
                    title={post.data.title}
                    size="base"
                    metaLayout="flex"
                  >
                    <Fragment slot="meta-below">
                      <span class="tabular">
                        {shortDateFormatter.format(post.data.publishedAt)}
                      </span>
                      <span class="text-rule-strong">·</span>
                      <span>
                        {post.data.authors.map((name, i) => {
                          const id = lookupFellowId(fellowByName, name);
                          return (
                            <>
                              {i > 0 && ', '}
                              {id ? (
                                <a href={`${import.meta.env.BASE_URL}/fellows/${id}`}>
                                  {name}
                                </a>
                              ) : (
                                name
                              )}
                            </>
                          );
                        })}
                      </span>
                    </Fragment>
                  </ListItem>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )
    }
  </article>
</Base>
