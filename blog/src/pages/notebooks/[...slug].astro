---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import ArticleHeader from '../../components/ArticleHeader.astro';
import Byline from '../../components/Byline.astro';
import { fellowByNameRecord } from '../../lib/fellow-id-map';
import { longDateFormatter } from '../../lib/date-formatters';

export async function getStaticPaths() {
  const notebooks = await getCollection('notebooks');
  const fellows = await getCollection('fellows');
  return notebooks.map((nb) => ({
    params: { slug: nb.id },
    props: { notebook: nb, fellowByName: fellowByNameRecord(fellows) },
  }));
}

const { notebook, fellowByName } = Astro.props;
const { Content } = await render(notebook);
---

<Base title={`${notebook.data.title} (Lab notebook)`}>
  <article class="prose">
    <ArticleHeader
      eyebrow="Lab notebook"
      title={notebook.data.title}
      size="sub"
      spacing="tight"
      notProse
      ruleMargin="mt-6"
      showRule={false}
    >
      <Byline
        authors={notebook.data.authors}
        fellowByName={fellowByName}
        topMargin="mt-4"
      >
        <span class="text-rule-strong">·</span>
        <span class="tabular">
          started{' '}
          <time datetime={notebook.data.startedAt.toISOString()}>
            {longDateFormatter.format(notebook.data.startedAt)}
          </time>
        </span>
        {
          notebook.data.completedAt && (
            <>
              <span class="text-rule-strong">·</span>
              <span class="tabular">
                completed{' '}
                <time datetime={notebook.data.completedAt.toISOString()}>
                  {longDateFormatter.format(notebook.data.completedAt)}
                </time>
              </span>
            </>
          )
        }
      </Byline>
      <p class="meta mt-3">
        Lab notebook for{' '}
        <a href={`${import.meta.env.BASE_URL}/posts/${notebook.data.postSlug}`}
          >the publication</a
        >.
      </p>
      <hr class="rule mt-6" />
    </ArticleHeader>

    <Content />
  </article>
</Base>
