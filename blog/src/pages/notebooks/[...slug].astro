---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notebooks = await getCollection('notebooks');
  return notebooks.map((nb) => ({
    params: { slug: nb.id },
    props: { notebook: nb },
  }));
}

const { notebook } = Astro.props;
const { Content } = await render(notebook);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${notebook.data.title} (Lab notebook)`}>
  <article class="prose">
    <header class="mb-10 not-prose">
      <p class="runninghead">Lab notebook</p>
      <h1 class="mt-3 text-2xl sm:text-3xl font-medium tracking-tight leading-[1.15]">
        {notebook.data.title}
      </h1>
      <div class="meta mt-4 flex flex-wrap gap-x-4 gap-y-1 items-baseline">
        <span>{notebook.data.authors.join(', ')}</span>
        <span class="text-rule-strong">·</span>
        <span class="tabular">
          started{' '}
          <time datetime={notebook.data.startedAt.toISOString()}>
            {dateFormatter.format(notebook.data.startedAt)}
          </time>
        </span>
        {
          notebook.data.completedAt && (
            <>
              <span class="text-rule-strong">·</span>
              <span class="tabular">
                completed{' '}
                <time datetime={notebook.data.completedAt.toISOString()}>
                  {dateFormatter.format(notebook.data.completedAt)}
                </time>
              </span>
            </>
          )
        }
      </div>
      <p class="meta mt-3">
        Lab notebook for{' '}
        <a href={`${import.meta.env.BASE_URL}/posts/${notebook.data.postSlug}`}
          >the publication</a
        >.
      </p>
      <hr class="rule mt-6" />
    </header>

    <Content />
  </article>
</Base>
