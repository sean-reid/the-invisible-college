---
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}

const { title, description, ogType = 'website' } = Astro.props;
const fullTitle =
  title === 'The Invisible College'
    ? title
    : `${title} · The Invisible College`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}/favicon.svg`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="The Invisible College"
      href={`${import.meta.env.BASE_URL}/rss.xml`}
    />
    <link
      rel="sitemap"
      href={`${import.meta.env.BASE_URL}/sitemap-index.xml`}
    />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:type" content={ogType} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
  </head>
  <body>
    <div class="mx-auto max-w-2xl px-6 py-10 sm:py-14">
      <header class="mb-12 sm:mb-16">
        <p class="runninghead">
          <a href={`${import.meta.env.BASE_URL}/`}>The Invisible College</a>
        </p>
        <hr class="rule mt-3" />
      </header>

      <main>
        <slot />
      </main>

      <footer class="mt-24 sm:mt-32">
        <hr class="rule mb-4" />
        <nav class="meta footer-nav">
          <a href={`${import.meta.env.BASE_URL}/about`}>About</a>
          <a href={`${import.meta.env.BASE_URL}/fellows`}>Fellows</a>
          <a href={`${import.meta.env.BASE_URL}/agenda`}>Agenda</a>
          <a href={`${import.meta.env.BASE_URL}/records`}>Records</a>
          <a href={`${import.meta.env.BASE_URL}/corrections`}>Corrections</a>
          <a href={`${import.meta.env.BASE_URL}/rss.xml`}>RSS</a>
        </nav>
        <p class="meta text-center mt-2 tabular">founded 2026</p>
      </footer>
    </div>
  </body>
</html>

<style>
  /* Footer nav: 3x2 grid on narrow screens (avoids the orphaned wrap
     when six items don't fit on one line); single bullet-separated
     row on wider screens, matching the rest of the site's meta lines. */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, max-content);
    justify-content: center;
    column-gap: 1.5rem;
    row-gap: 0.25rem;
  }
  @media (min-width: 640px) {
    .footer-nav {
      display: flex;
      justify-content: center;
      column-gap: 0;
    }
    .footer-nav > a + a::before {
      content: '·';
      color: var(--color-rule-strong);
      margin: 0 0.5rem;
      display: inline-block;
      text-decoration: none;
    }
  }
</style>
