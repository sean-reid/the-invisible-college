---
import { lookupFellowId } from '../lib/fellow-id-map';
import type { FellowByName, FellowByNameRecord } from '../lib/fellow-id-map';

/**
 * Authors-and-date metadata line used on posts, notebooks, reviews and
 * preprints. The default slot is rendered after the authors block,
 * preceded by the same `·` separator the original handwritten copies
 * used. Caller drops further metadata pieces (dates, version numbers,
 * dissent notes) into the slot.
 */
interface Props {
  authors: string[];
  fellowByName?: FellowByName | FellowByNameRecord;
  /**
   * Top margin variant. Posts and preprints use `mt-5`, notebooks use
   * `mt-4`. Defaults to `mt-5` (the most common case).
   */
  topMargin?: 'mt-4' | 'mt-5';
  /**
   * Extra classes appended to the default wrapper.
   */
  class?: string;
}

const {
  authors,
  fellowByName,
  topMargin = 'mt-5',
  class: extraClass = '',
} = Astro.props;

const BASE = import.meta.env.BASE_URL;

const wrapperClass = [
  `meta ${topMargin} flex flex-wrap gap-x-4 gap-y-1 items-baseline`,
  extraClass,
]
  .filter(Boolean)
  .join(' ');
---

<div class={wrapperClass}>
  <span>
    {
      authors.map((name, i) => {
        const id = lookupFellowId(fellowByName, name);
        return (
          <>
            {i > 0 && ', '}
            {id ? <a href={`${BASE}/fellows/${id}`}>{name}</a> : name}
          </>
        );
      })
    }
  </span>
  <slot />
</div>
