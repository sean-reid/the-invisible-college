{
  "name": "the-invisible-college-blog",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "sync-fellows": "node scripts/sync-fellows.mjs",
    "sync-decisions": "node scripts/sync-decisions.mjs",
    "sync-preprints": "node scripts/sync-preprints.mjs",
    "sync": "node scripts/sync-fellows.mjs && node scripts/sync-decisions.mjs && node scripts/sync-preprints.mjs",
    "dev": "npm run sync && astro dev",
    "start": "npm run sync && astro dev",
    "build": "npm run sync && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run sync && astro check",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,js,jsx,md,mdx}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,jsx,md,mdx}\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.3",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.5",
    "katex": "^0.16.47",
    "marked": "^18.0.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.17.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "node": ">=20"
  }
}
