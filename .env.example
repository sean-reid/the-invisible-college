# Operator-local secrets and per-operator overrides for the daemon.
# Copy this to .env (which is gitignored) and fill in real values.
#
# scripts/run-daemon.sh sources the .env file at the top of every
# cycle. Anything set here is exported into the daemon's environment.
# The launchd plist's EnvironmentVariables are still applied first
# (launchd sets them before the script runs); .env values then
# override or supplement them.

# ntfy.sh topic for per-cycle notifications. Treat as semi-secret:
# anyone with the topic can subscribe to (and publish to) the
# notification stream. Leave unset to disable notifications.
# IC_NTFY_TOPIC=your-random-topic-here

# Alternate ntfy server. Defaults to https://ntfy.sh.
# IC_NTFY_SERVER=https://ntfy.example.com
