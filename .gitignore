# Runtime state
/fellows/
institute.db
institute.db-shm
institute.db-wal
.autopilot.lock
.daemon-cycle.pre-status
*.log
bootstrap-failed-output.txt
archive/lab-notebooks/*/raw-research-output.txt
archive/reviews/*/raw-review-by-*.txt
# Promotion-review scratch space the orchestrator rewrites every run.
# Not institutional record — those live in the per-Fellow vote dirs.
archive/promotions/_orchestrator-workspace/
# Admissions scratch space same shape: rewritten per admit run, the
# canonical artifacts live in archive/admissions/<candidate-id>/.
archive/admissions/_orchestrator-workspace/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Node / Astro
node_modules/
blog/dist/
blog/.astro/
blog/screenshots/
# Synced from /genomes at build time by scripts/sync-fellows.mjs.
blog/src/content/fellows/*.json
# Synced from /archive/decisions at build time by scripts/sync-decisions.mjs.
blog/src/content/decisions/*.md
# Synced from /archive/preprints at build time by scripts/sync-preprints.mjs.
blog/src/content/preprints/*.md
.DS_Store

# Playwright
test-results/
playwright-report/
playwright/.cache/

# AI tool traces (never commit)
.claude/
CLAUDE.md

# Environment
.env
.env.local
*.local

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
